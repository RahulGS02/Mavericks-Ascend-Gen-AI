# ============================================================
# Mavericks Ascend — Backend Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<supabase-service-role-key>

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development

# ── File upload limits ────────────────────────────────────────
MAX_UPLOAD_SIZE=10485760
MAX_RESUME_SIZE=5242880
MAX_EXCEL_SIZE=10485760

# ============================================================
#  AI Configuration — Azure AI Foundry (PRIMARY)
# ============================================================
#
#  How to get these values:
#  1. Go to https://ai.azure.com  →  Your Project
#  2. Left sidebar → "Models + endpoints"
#  3. Click on your "gpt-4o-mini" deployment
#  4. Copy "Target URI" → AZURE_AI_ENDPOINT
#  5. Copy "Key 1"      → AZURE_AI_API_KEY
#
AI_ENABLED=True
AI_PROVIDER=azure

AZURE_AI_ENDPOINT=https://<your-project>.inference.ai.azure.com
AZURE_AI_API_KEY=<your-azure-ai-primary-key>
AZURE_AI_MODEL=gpt-4o-mini
AZURE_AI_MAX_TOKENS=4000
AZURE_AI_TEMPERATURE=0.7

# ── AI Usage limits ───────────────────────────────────────────
AI_DAILY_REQUEST_LIMIT=1000
AI_RATE_LIMIT_PER_MINUTE=60

# ── AI Feature flags (set False to disable individual features)
AI_RESUME_PARSING_ENABLED=True
AI_SKILL_EXTRACTION_ENABLED=True
AI_PERFORMANCE_INSIGHTS_ENABLED=True

# ── Anthropic (optional fallback — set AI_PROVIDER=anthropic) ─
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Auggie SDK (legacy — no longer recommended) ───────────────
# AI_PROVIDER=auggie
# AI_API_KEY=<auggie-key>
# AI_MODEL=claude-sonnet-4.5
