# ============================================
# DEVELOPMENT ENVIRONMENT
# ============================================

# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maverick_db

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# AI Configuration - ENABLED FOR DEVELOPMENT
AI_ENABLED=true
AI_API_KEY=your_auggie_api_key_here
AI_MODEL=claude-sonnet-4.5
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# AI Usage Limits - GENEROUS FOR TESTING
AI_DAILY_REQUEST_LIMIT=1000
AI_RATE_LIMIT_PER_MINUTE=60

# AI Feature Flags - ALL ENABLED
AI_RESUME_PARSING_ENABLED=true
AI_SKILL_EXTRACTION_ENABLED=true
AI_PERFORMANCE_INSIGHTS_ENABLED=true

# JWT
JWT_SECRET=your_dev_jwt_secret_minimum_32_characters_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Upload Limits
MAX_UPLOAD_SIZE=10485760
MAX_RESUME_SIZE=5242880
MAX_EXCEL_SIZE=10485760

# Allowed File Types
ALLOWED_RESUME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
ALLOWED_EXCEL_TYPES=application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv
