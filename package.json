{
  "name": "maverick-insights",
  "version": "1.0.0",
  "description": "AI-Powered Training Performance & Competency Tracking Dashboard",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run dev",
    "build": "npm run build:web",
    "build:web": "cd apps/web && npm run build",
    "start": "npm run start:web",
    "start:web": "cd apps/web && npm run start",
    "lint": "npm run lint:web",
    "lint:web": "cd apps/web && npm run lint",
    "test": "echo \"Tests coming soon\"",
    "clean": "rimraf apps/*/node_modules apps/*/.next apps/*/dist node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "Maverick Insights Team",
  "license": "PROPRIETARY"
}
